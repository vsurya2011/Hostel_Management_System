              "mode": "raw",
              "raw": "{\n  \"userId\": 2,\n  \"rollNumber\": \"CS2024001\",\n  \"name\": \"John Doe\",\n  \"phone\": \"9999999999\",\n  \"department\": \"CSE\",\n  \"year\": 2,\n  \"guardianName\": \"Jane Doe\",\n  \"guardianPhone\": \"8888888888\",\n  \"address\": \"123 Main St\",\n  \"admissionDate\": \"2024-07-01\"\n}"
